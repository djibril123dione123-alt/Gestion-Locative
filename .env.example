# =============================================================================
# Variables d'environnement - Samay Këur (Confort Immo Archi)
# =============================================================================
# Sur Replit, configurer ces valeurs via le panneau "Secrets" (icône verrou),
# JAMAIS dans un fichier commité au dépôt.
# =============================================================================

# URL publique de l'instance Supabase
# Format : https://<project-ref>.supabase.co
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Clé anonyme (publique) Supabase
# Trouvable dans Project Settings > API > anon public
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Clé service (secrète) Supabase - pour les opérations serveur
# ATTENTION: Ne jamais exposer côté client !
# SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Environnement (development/staging/production)
VITE_ENV=development

# URL de base de l'application (pour les redirections)
VITE_APP_URL=http://localhost:5000

# Configuration Sentry (optionnel - monitoring erreurs)
# VITE_SENTRY_DSN=
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=your-auth-token

# Analytics PostHog (optionnel)
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://eu.posthog.com
